# Kan — Environment Variables
# https://github.com/kanbn/kan?tab=readme-ov-file#environment-variables-)
#
# This project deploys on Cloudflare Workers (D1 + R2 + KV).
# Most secrets are set via `wrangler secret put` — see apps/worker/wrangler.toml.example.
# The vars below are used at build time by the frontend and/or by local dev tooling.

# ── Required ─────────────────────────────────────────────────────────
# Base URL of the Worker (local dev or production)
NEXT_PUBLIC_BASE_URL=http://localhost:8787

# Auth secret — 32+ char random string
# Generate with: openssl rand -base64 26 | tr -dc 'a-zA-Z0-9' | head -c 32
BETTER_AUTH_SECRET=

# Encryption key — 32+ char random string (used for encrypting tokens at rest)
ENCRYPTION_KEY=

# ── Auth behaviour ───────────────────────────────────────────────────
# Enable email + password login (set to "true" to allow, leave empty to disable)
# When disabled, users can only log in via OAuth providers (Google, GitHub, etc.)
NEXT_PUBLIC_ALLOW_CREDENTIALS=true

# Disable new user sign-ups (optional, default: false)
# NEXT_PUBLIC_DISABLE_SIGN_UP=

# ── Email (optional — via Resend on CF Workers) ──────────────────────
# Set these as wrangler secrets for production:
#   wrangler secret put EMAIL_API_KEY
#   wrangler secret put EMAIL_FROM
# EMAIL_API_KEY=
# EMAIL_FROM="Kan <hello@example.com>"

# Switch email features off entirely (optional)
# NEXT_PUBLIC_DISABLE_EMAIL=true

# ── Stripe (optional) ───────────────────────────────────────────────
# Set as wrangler secrets:
#   wrangler secret put STRIPE_SECRET_KEY
#   wrangler secret put STRIPE_WEBHOOK_SECRET

# ── OAuth providers (optional) ──────────────────────────────────────
# Set as wrangler secrets or [vars] in wrangler.toml.
# BETTER_AUTH_TRUSTED_ORIGINS=
# BETTER_AUTH_ALLOWED_DOMAINS=   # Restrict sign-ins to specific email domains (comma-separated)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_ISSUER=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_APP_BUNDLE_IDENTIFIER=

# ── Integration providers (optional) ────────────────────────────────
# TRELLO_APP_API_KEY=
# TRELLO_APP_SECRET=

# ── Logging (optional) ──────────────────────────────────────────────
# debug | info | warn | error (defaults to debug in dev, info in prod)
# LOG_LEVEL=
