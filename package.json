{
  "name": "kan",
  "private": true,
  "engines": {
    "node": ">=20.18.1",
    "pnpm": "^9.14.2"
  },
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "build": "turbo run build",
    "build:web": "cd apps/web && pnpm build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:migrate": "cd packages/db && pnpm migrate",
    "db:migrate:local": "cd apps/worker && npx wrangler d1 migrations apply kan-db --local",
    "db:migrate:remote": "cd apps/worker && npx wrangler d1 migrations apply kan-db --remote",
    "db:push": "turbo -F @kan/db push",
    "db:studio": "turbo -F @kan/db studio",
    "ship": "pnpm build:web && cd apps/worker && npx wrangler deploy",
    "ship:worker": "cd apps/worker && npx wrangler deploy",
    "dev": "turbo watch dev --filter='!@kan/docs' --continue",
    "dev:all": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @kan/web...",
    "dev:worker": "pnpm build:web && cd apps/worker && npx wrangler dev",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "smoke-test": "bash scripts/smoke-test.sh",
    "smoke-test:prod": "bash scripts/smoke-test.sh https://kan.YOUR_SUBDOMAIN.workers.dev",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@kan/prettier-config": "workspace:*",
    "@turbo/gen": "^2.8.20",
    "prettier": "catalog:",
    "turbo": "^2.8.20",
    "typescript": "catalog:"
  },
  "prettier": "@kan/prettier-config",
  "pnpm": {
    "overrides": {
      "@types/minimatch": "npm:minimatch@*",
      "@types/glob": "npm:@types/glob@^8.1.0"
    }
  }
}
